{
  "name": "plugin-documents",
  "version": "0.1.0",
  "description": "Paperclip plugin for browsing all issue documents across the company",
  "type": "module",
  "main": "dist/worker.mjs",
  "paperclipPlugin": {
    "manifest": "dist/plugin-manifest.mjs"
  },
  "scripts": {
    "build": "node build.mjs",
    "prepack": "node build.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "dev": "paperclip-plugin-dev-server --root . --ui-dir dist/ui --port 4178"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": ">=2026.416.0",
    "marked": "^18.0.3"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "esbuild": "^0.25.12",
    "react": "^19.0.0",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
